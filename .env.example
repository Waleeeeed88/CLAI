# Provider keys. Add only the providers you route roles to.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter metadata.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=CLAI

# GitHub MCP integration.
GITHUB_TOKEN=
GITHUB_MCP_ENABLED=false
GITHUB_MCP_COMMAND=npx
GITHUB_MCP_ARGS=-y @modelcontextprotocol/server-github

# Default role models.
SENIOR_DEV_MODEL=claude-opus-4-8
CODER_MODEL=claude-sonnet-4-6
CODER_MODEL_2=gemini-3.1-pro-preview
CODER_MODEL_3=kimi-k2-thinking
QA_MODEL=gemini-3.5-flash
BA_MODEL=gpt-5.5
REVIEWER_MODEL=claude-sonnet-4-6

# Optional per-role overrides.
# ROLE_PROVIDER_OVERRIDES={"coder":"openrouter","reviewer":"openrouter"}
# ROLE_MODEL_OVERRIDES={"coder":"~anthropic/claude-sonnet-latest","reviewer":"~anthropic/claude-sonnet-latest"}

DEFAULT_MAX_TOKENS=8192
DEFAULT_TEMPERATURE=0.7
VERBOSE=true
LOG_LEVEL=DEBUG

MCP_ENABLED=true
MCP_WORKSPACE_ROOT=./workspace
ENTERPRISE_DATA_ENABLED=true
ENTERPRISE_DATA_DIR=.clai_data
SCRATCHPAD_ENABLED=true
QA_TOOLS_ENABLED=true
